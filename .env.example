APP_ENV=local
APP_DEBUG=true

APP_NAME="SHIVA RP"
APP_DESCRIPTION="A roleplay server for FiveM"
APP_TAGS="roleplay,fivem,shiva"

MAX_PLAYERS=32

# Format: mysql://username:password@host:port/database?charset=utf8mb4
# For Docker: use host.docker.internal instead of localhost
DB_USERNAME=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fivem
DB_CHARSET=utf8mb4
DB_CONNECTION="mysql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}?charset=${DB_CHARSET}"

LICENSE_KEY=
STEAM_KEY=

RCON_PASSWORD=changeme

NO_DEFAULT_CONFIG=
NO_LICENSE_KEY=
NO_STEAM_KEY=
NO_ONESYNC=

FIVEM_ID=
DISCORD_ID=
TXADMIN_PASSWORD=

FORWARD_FIVEM_PORT=30120
FORWARD_TXADMIN_PORT=40120
